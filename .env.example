# LuxQuant Terminal - Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://luxquant:password@localhost:5432/luxquant
POSTGRES_USER=luxquant
POSTGRES_PASSWORD=password
POSTGRES_DB=luxquant

# Redis
REDIS_URL=redis://localhost:6379

# Backend
SECRET_KEY=your-secret-key-here
LUXQUANT_JWT_SECRET=your-shared-cryptobot-secret-at-least-32-chars
LUXQUANT_CRYPTOBOT_TOKEN_EXPIRE_SECONDS=3600
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws
VITE_AUTOTRADE_API_URL=https://api.cryptobot.id

