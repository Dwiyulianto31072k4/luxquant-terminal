# LuxQuant Terminal - Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://luxquant:password@localhost:5432/luxquant
POSTGRES_USER=luxquant
POSTGRES_PASSWORD=password
POSTGRES_DB=luxquant

# Redis
REDIS_URL=redis://localhost:6379

# Backend
SECRET_KEY=your-secret-key-here
LUXQUANT_JWT_SECRET=your-shared-cryptobot-secret-at-least-32-chars
LUXQUANT_CRYPTOBOT_TOKEN_EXPIRE_SECONDS=3600
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws
VITE_AUTOTRADE_API_URL=https://api.cryptobot.id

# Social post automation
SOCIAL_POST_ASSETS_DIR=/opt/luxquant/social-posts
SOCIAL_POST_DEFAULT_PLATFORM=x
SOCIAL_POST_PUBLISH_LIMIT=5
NEWS_EXTRACT_MIN_CHARS=350
NEWS_EXTRACT_TIMEOUT=20
JINA_API_KEY=
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_QUALITY=medium
SOCIAL_IMAGE_TIMEOUT=120
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_ACCOUNT_HANDLE=luxquantcrypto
TELEGRAM_BOT_TOKEN=
TELEGRAM_SOCIAL_CHAT_ID=
