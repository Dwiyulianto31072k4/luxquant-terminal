[Unit]
Description=LuxQuant AI Arena v6 — 4x/day timer (00:00 / 06:00 / 12:00 / 18:00 UTC)
Requires=luxquant-arena-v6.service

[Timer]
# Fires at 00:00, 06:00, 12:00, 18:00 UTC every day
OnCalendar=*-*-* 00,06,12,18:00:00 UTC
# If missed (e.g., VPS down), run as soon as possible
Persistent=true
# Small randomized delay to avoid clashing with other timer-triggered services
RandomizedDelaySec=30
Unit=luxquant-arena-v6.service

[Install]
WantedBy=timers.target
