[Unit]
Description=LuxQuant BTC Compass 2.0 — Daily Reflection (brain vault learning loop)
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/root/luxquant-terminal/backend
Environment="PYTHONUNBUFFERED=1"
Environment="COMPASS_BRAIN_DIR=/root/luxquant-brain"
ExecStart=/root/luxquant-terminal/backend/venv/bin/python -m app.services.compass_reflection
StandardOutput=journal
StandardError=journal
TimeoutStartSec=300
