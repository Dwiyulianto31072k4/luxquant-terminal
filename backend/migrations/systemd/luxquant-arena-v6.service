[Unit]
Description=LuxQuant AI Arena v6 — Scheduled Report Generator
After=network-online.target postgresql.service redis-server.service
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/root/luxquant-terminal/backend
Environment="PYTHONUNBUFFERED=1"
ExecStart=/root/luxquant-terminal/backend/migrations/run_compass_with_lock.sh scheduled
StandardOutput=journal
StandardError=journal
TimeoutStartSec=300
