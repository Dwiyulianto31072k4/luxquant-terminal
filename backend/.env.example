# Database
DATABASE_URL=postgresql://user:password@localhost:5432/luxquant

# App Settings
DEBUG=false
API_KEY=your-api-key-here

# CORS (comma-separated origins)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# BTC Compass estimated liquidation map (Binance public futures data, no key)
# Minimum model confidence required before deterministic/shadow decision use.
COMPASS_LIQUIDITY_MIN_CONFIDENCE=0.52

# Legacy CoinAnk actor credentials are optional and no longer used as primary.
# APIFY_TOKEN=your-apify-token-here

# Keep false until eligible shadow results pass the activation gates.
COMPASS_DETERMINISTIC_VERDICT=false

# Social post automation
SOCIAL_POST_ASSETS_DIR=/opt/luxquant/social-posts
SOCIAL_POST_DEFAULT_PLATFORM=x
SOCIAL_POST_PUBLISH_LIMIT=5
NEWS_EXTRACT_MIN_CHARS=350
NEWS_EXTRACT_TIMEOUT=20
JINA_API_KEY=
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_QUALITY=medium
SOCIAL_IMAGE_TIMEOUT=120

# X publishing credentials (required only for approved X posts)
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_ACCOUNT_HANDLE=luxquantcrypto

# Telegram publishing credentials (required only for approved Telegram posts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_SOCIAL_CHAT_ID=
